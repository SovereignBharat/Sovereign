{
  "name": "sovereign",
  "version": "0.1.0",
  "description": "India's open publishing platform for authoritative opinions",
  "private": true,
  "license": "MIT",
  "author": "SovereignBharat Contributors",
  "homepage": "https://github.com/SovereignBharat/Sovereign",
  "repository": {
    "type": "git",
    "url": "https://github.com/SovereignBharat/Sovereign.git"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "test": "turbo run test",
    "test:watch": "turbo run test:watch",
    "test:e2e": "turbo run test:e2e",
    "test:integration": "turbo run test:integration",
    "test:coverage": "turbo run test:coverage",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "format": "turbo run format",
    "type-check": "turbo run type-check",
    "db:migrate": "cd apps/api && pnpm db:migrate",
    "db:seed": "cd apps/api && pnpm db:seed",
    "db:studio": "cd apps/api && pnpm db:studio",
    "clean": "turbo run clean && rm -rf node_modules .turbo",
    "preinstall": "npx only-allow pnpm",
    "prepare": "husky install 2>/dev/null || true",
    "editor:setup": "pnpm --filter @sovereign/editor setup",
    "editor:build": "pnpm --filter @sovereign/editor build",
    "editor:dev:agents": "pnpm --filter @sovereign/editor dev:agents",
    "editor:dev:web": "pnpm --filter @sovereign/editor dev:web",
    "editor:validate": "pnpm --filter @sovereign/editor validate",
    "web:dev": "pnpm --filter @sovereign/web dev",
    "web:build": "pnpm --filter @sovereign/web build",
    "web:type-check": "pnpm --filter @sovereign/web type-check"
  },
  "devDependencies": {
    "@turbo/gen": "^1.12.0",
    "turbo": "^1.12.0",
    "typescript": "^5.3.0",
    "eslint": "^8.55.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.1.0",
    "husky": "^8.0.0",
    "lint-staged": "^15.2.0"
  },
  "pnpm": {
    "overrides": {
      "typescript": "^5.3.0"
    }
  }
}
